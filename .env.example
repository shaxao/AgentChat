# ==================================================
# Backend Service Unified Env
# 这一组建议统一放到 Java 后端 systemd override 或服务器 env 文件里。
# 位置示例：
#   /etc/systemd/system/muhugochat.service.d/override.conf
#
# 修改后执行：
#   systemctl daemon-reload
#   systemctl restart muhugochat
# ==================================================

# ---- Security / Auth ----
# JWT 签名密钥。必须是长随机字符串，建议至少 64 字符。
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-64-characters

# ---- Payment ----
# 支付配置敏感字段 AES 加密密钥。必须长期稳定保存，否则已保存的支付密钥无法解密。
# 建议 32 字节以上随机字符串。
PAY_AES_KEY=change-this-to-a-32-byte-or-longer-random-secret

# ---- Internal Service Bridge ----
# Java 后端和 AutoCode 内部接口共享密钥。两边必须一致。
INTERNAL_API_KEY=change-this-internal-api-key
MUHUGOCHAT_INTERNAL_API_KEY=change-this-internal-api-key

# ---- Cache Ledger ----
# 平台级缓存账本服务地址。单机部署通常指向 AutoCode 后端本机端口。
CACHE_LEDGER_BASE_URL=http://127.0.0.1:8000/api/cache
CACHE_LEDGER_TIMEOUT_MS=2500

# ---- CORS ----
# 前端允许访问后端的来源，多个地址用英文逗号分隔。
CORS_ALLOWED_ORIGINS=http://your-server-b-ip,https://muhuo.cloud,https://www.muhuo.cloud,http://localhost:5173

# ---- Linux.do OAuth Login ----
# 登录页“使用 Linux.do 登录”按钮使用。
# Linux.do 应用后台 redirect_uri 必须与 LINUXDO_OAUTH_REDIRECT_URI 完全一致。
LINUXDO_OAUTH_CLIENT_ID=
LINUXDO_OAUTH_CLIENT_SECRET=
LINUXDO_OAUTH_REDIRECT_URI=http://your-server-b-ip/api/auth/oauth/linuxdo/callback
LINUXDO_OAUTH_FRONTEND_SUCCESS_URL=http://your-server-b-ip
LINUXDO_OAUTH_AUTHORIZE_ENDPOINT=https://connect.linux.do/oauth2/authorize
LINUXDO_OAUTH_TOKEN_ENDPOINT=https://connect.linuxdo.org/oauth2/token
LINUXDO_OAUTH_USERINFO_ENDPOINT=https://connect.linuxdo.org/api/user

# ==================================================
# AI Chat Platform - 生产环境配置模板
# 使用说明：复制此文件为 .env，填写真实值后启动
#   cp .env.example .env
# ==================================================

# -------- 数据库配置 --------
# MySQL root 密码（仅 Docker 初始化时使用）
MYSQL_ROOT_PASSWORD=your_root_password_here

# 应用数据库名、用户名、密码
DB_NAME=aiplatform
DB_USERNAME=aiplatform
DB_PASSWORD=your_db_password_here

# -------- Redis 配置 --------
REDIS_PASSWORD=your_redis_password_here

# -------- JWT 密钥 --------
# 建议使用随机字符串（至少 64 个字符）
# 生成命令：openssl rand -base64 64
JWT_SECRET=change-this-to-a-very-long-random-secret-key-at-least-64-characters

# -------- 邮件配置 --------
# QQ 邮箱示例（需在 QQ 邮箱设置中开启 SMTP 并获取授权码）
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your_email@qq.com
MAIL_PASSWORD=your_email_auth_code

# 其他邮箱示例（163邮箱）：
# MAIL_HOST=smtp.163.com
# MAIL_PORT=465
# MAIL_USERNAME=your_email@163.com
# MAIL_PASSWORD=your_email_auth_code

# -------- AI 默认配置 --------
# 当数据库中没有配置渠道时使用此兜底配置
AI_API_KEY=sk-your-openai-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_DEFAULT_MODEL=gpt-4o-mini

# -------- 端口配置（可选，默认值如下）--------
FRONTEND_PORT=80
BACKEND_PORT=8080
MYSQL_PORT=3306
REDIS_PORT=6379

# -------- Linux.do OAuth 登录配置 --------
# 用途：登录页“使用 Linux.do 登录”按钮。
# 后端会使用 OAuth2 authorization_code 流程：
#   1. 跳转到 LINUXDO_OAUTH_AUTHORIZE_ENDPOINT
#   2. 回调到 LINUXDO_OAUTH_REDIRECT_URI
#   3. 通过 LINUXDO_OAUTH_TOKEN_ENDPOINT 换 access_token
#   4. 通过 LINUXDO_OAUTH_USERINFO_ENDPOINT 读取 id/username/name/avatar/trust_level
#
# Linux.do 应用后台的 redirect_uri 必须与 LINUXDO_OAUTH_REDIRECT_URI 完全一致。
# 示例：
#   LINUXDO_OAUTH_REDIRECT_URI=http://your-server-b-ip/api/auth/oauth/linuxdo/callback
#   LINUXDO_OAUTH_FRONTEND_SUCCESS_URL=http://your-server-b-ip
#
# 注意：client secret 是敏感密钥，不要提交到 Git；生产环境建议通过 systemd Environment 或服务器密钥管理注入。
LINUXDO_OAUTH_CLIENT_ID=
LINUXDO_OAUTH_CLIENT_SECRET=
LINUXDO_OAUTH_REDIRECT_URI=http://localhost:8080/api/auth/oauth/linuxdo/callback
LINUXDO_OAUTH_FRONTEND_SUCCESS_URL=http://localhost:5173
LINUXDO_OAUTH_AUTHORIZE_ENDPOINT=https://connect.linux.do/oauth2/authorize
LINUXDO_OAUTH_TOKEN_ENDPOINT=https://connect.linuxdo.org/oauth2/token
LINUXDO_OAUTH_USERINFO_ENDPOINT=https://connect.linuxdo.org/api/user
