# AutoCode Agent Platform environment.
# Copy this file to .env and fill real values.
# Do not commit real .env files.

# ---------------------------------------------------------------------
# MuhugoChat database
# AutoCode can read model/channel configuration from the Java system DB.
# ---------------------------------------------------------------------
MUHUGOCHAT_DB_HOST=localhost
MUHUGOCHAT_DB_PORT=3306
MUHUGOCHAT_DB_NAME=MuHuoAi
MUHUGOCHAT_DB_USER=muhuoai
MUHUGOCHAT_DB_PASSWORD=changeme

# ---------------------------------------------------------------------
# Optional direct LLM provider keys
# Prefer model_channel records in the Java system for production.
# These are useful for local smoke tests.
# ---------------------------------------------------------------------
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
QWEN_API_KEY=
KIMI_API_KEY=

# Optional direct model override. Leave commented to use DB routing.
# AUTOCODE_MODEL=deepseek-v4-pro
# AUTOCODE_API_KEY=
# AUTOCODE_BASE_URL=https://api.deepseek.com
# AUTOCODE_PROVIDER=openai

# ---------------------------------------------------------------------
# Workspace and execution
# ---------------------------------------------------------------------
WORKSPACE_BASE_DIR=./workspaces
AUTOCODE_WORKSPACE_MAX_SIZE_MB=5120
AUTOCODE_WORKSPACE_CLEANUP_DAYS=7
AUTOCODE_DEV_SERVER_IDLE_TIMEOUT=1800
MAX_CONCURRENT_TASKS=5

# Docker execution. Remove or leave blank to use local fallback where supported.
DOCKER_WORKSPACE_IMAGE=agent-workspace:latest
# Windows Docker Desktop: npipe:////./pipe/docker_engine
# Linux/macOS: unix:///var/run/docker.sock
DOCKER_HOST=npipe:////./pipe/docker_engine
AUTOCODE_DOCKER_MEM_LIMIT=2g
AUTOCODE_DOCKER_CPU_LIMIT=2.0

# ---------------------------------------------------------------------
# Public URLs
# Used for preview URLs and cross-service links.
# ---------------------------------------------------------------------
# Example: your-server-b-ip:8000 or autocode.example.com
AUTOCODE_PUBLIC_HOST=localhost:8000

# Java backend internal admin API, used for model/channel config and usage report.
# Local example: http://127.0.0.1:8080/api/admin
# Production behind Nginx example: http://127.0.0.1:8080/api/admin
MUHUGOCHAT_API_URL=http://127.0.0.1:8080/api/admin
INTERNAL_API_KEY=
MUHUGOCHAT_INTERNAL_API_KEY=

# Shared cache ledger service. Leave blank to disable.
CACHE_LEDGER_BASE_URL=

# ---------------------------------------------------------------------
# Git identity used for AutoCode workspace commits.
# ---------------------------------------------------------------------
GIT_AUTHOR_NAME=AutoCode Agent
GIT_AUTHOR_EMAIL=agent@autocode.local

# ---------------------------------------------------------------------
# Optional deployment integrations
# ---------------------------------------------------------------------
VERCEL_API_TOKEN=

# Logging
LOG_LEVEL=INFO
