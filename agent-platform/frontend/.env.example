# AutoCode standalone frontend environment.
# Copy this file to .env.local when running the standalone Next.js frontend.

# AutoCode backend HTTP API.
# Local development: http://localhost:8000
# Production behind Nginx: /autocode-api
NEXT_PUBLIC_API_URL=/autocode-api

# AutoCode backend WebSocket URL.
# Local development: ws://localhost:8000
# Production can usually be omitted; the frontend derives it from NEXT_PUBLIC_API_URL.
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
