# Main React frontend environment.
# Copy this file to .env for local development.

# Java backend API base URL.
# Local development example: http://localhost:8080/api
# Production behind Nginx: /api
VITE_API_URL=/api

# Demo mode uses mock data. Set false when connected to the backend.
VITE_DEMO_MODE=false

# AutoCode backend API base URL.
# Local development example: http://localhost:8000
# Production behind Nginx: /autocode-api
VITE_AUTOCODE_API_URL=/autocode-api

# AutoCode standalone frontend URL.
# Local development example: http://localhost:3000
# Production behind Nginx: /autocode
NEXT_PUBLIC_AUTOCODE_URL=/autocode
